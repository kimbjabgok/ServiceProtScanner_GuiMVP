{
  "version": 6,
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default (vcpkg + system Qt)",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "CMAKE_CXX_STANDARD": "20"
      }
    },
    {
      "name": "no-vcpkg",
      "displayName": "System only (no vcpkg)",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "20"
      }
    }
  ]
}
